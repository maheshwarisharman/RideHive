<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rh_screen_bg">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="18dp">

            <!-- Top bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_avatar_1"
                    app:shapeAppearanceOverlay="@style/RideHive.CircleImage" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Campus Cab-Pool"
                    android:textColor="@color/rh_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_bell"
                    app:shapeAppearanceOverlay="@style/RideHive.CircleImage"
                    app:strokeColor="@color/rh_divider"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <!-- Destination -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_search"
                app:hintEnabled="false"
                app:boxBackgroundMode="none"
                app:startIconDrawable="@drawable/ic_search"
                app:startIconTint="@color/rh_text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_destination"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="Where to?"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="true"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:textColor="@color/rh_text_primary"
                    android:textColorHint="@color/rh_text_secondary"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Map card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/rh_card_bg"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/rh_divider"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">

                    <androidx.fragment.app.FragmentContainerView
                        android:id="@+id/map_fragment"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:name="com.google.android.gms.maps.SupportMapFragment"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Zoom controls -->
                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="96dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_zoom"
                        android:gravity="center"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/btn_zoom_in"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_plus"
                            app:tint="@color/rh_text_primary" />

                        <View
                            android:layout_width="22dp"
                            android:layout_height="1dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="10dp"
                            android:background="@color/rh_divider" />

                        <ImageView
                            android:id="@+id/btn_zoom_out"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_minus"
                            app:tint="@color/rh_text_primary" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pool_now"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="Pool Now"
                android:textAllCaps="false"
                android:textColor="@color/rh_on_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_users"
                app:iconPadding="10dp"
                app:iconTint="@color/rh_on_primary"
                app:backgroundTint="@color/rh_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_schedule_later"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="Schedule for later"
                android:textAllCaps="false"
                android:textColor="@color/rh_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_calendar"
                app:iconPadding="10dp"
                app:iconTint="@color/rh_text_primary"
                app:strokeColor="@color/rh_divider"
                app:strokeWidth="1dp"
                app:backgroundTint="@color/rh_card_bg" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Nearby Riders"
                android:textColor="@color/rh_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_nearby_riders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false" />

            <View
                android:layout_width="match_parent"
                android:layout_height="18dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:background="@color/rh_card_bg"
        app:itemIconTint="@color/rh_bottom_nav_item"
        app:itemTextColor="@color/rh_bottom_nav_item"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_bottom_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

